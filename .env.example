# =============================================================================
# RedBeard Social Agent — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# --- LLM (xAI Grok recommended; any OpenAI-compatible API works) ---
# Get an xAI key at https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here
# Base URL for xAI (OpenAI-compatible). Leave as-is for Grok.
XAI_BASE_URL=https://api.x.ai/v1
# Model name — e.g. grok-2-latest, grok-3, or grok-4 when available
XAI_MODEL=grok-2-latest

# Optional: use OpenAI instead of xAI (set USE_OPENAI=true)
USE_OPENAI=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Dashboard ---
# Change this secret in production (used for Flask sessions)
FLASK_SECRET_KEY=change-me-to-a-long-random-string
# Bind address: 127.0.0.1 for local-only, 0.0.0.0 for LAN access
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5050
# Simple password gate for the review dashboard (leave empty to disable)
DASHBOARD_PASSWORD=redbeard

# --- Paths (optional overrides; defaults work on Pi) ---
# DATA_DIR=/home/pi/redbeard-social-agent/data
# LOG_LEVEL=INFO

# --- Safety ---
# NEVER set this to true in v1 unless you have fully implemented + tested publishers
AUTO_POST_ENABLED=false
